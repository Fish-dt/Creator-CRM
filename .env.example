# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Frontend / API Gateway ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── PostgreSQL (Docker Compose) ───────────────────────────────────────────────
POSTGRES_DB=creator_crm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Spring Services ───────────────────────────────────────────────────────────
# use docker service hostname "postgres"
DB_URL=jdbc:postgresql://postgres:5432/creator_crm
DB_USER=postgres
DB_PASS=postgres

# ── Kafka ─────────────────────────────────────────────────────────────────────
# use docker service hostname "kafka"
KAFKA_BROKERS=kafka:29092

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-long-random-secret-min-32-chars

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# use docker service hostname "otel-collector"
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=deal-service

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123